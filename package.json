{
  "name": "bdralph",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "bdralph": "bin/bdralph"
  },
  "scripts": {
    "test": "cd fixtures/playground && npm test",
    "test:watch": "cd fixtures/playground && npm run test:watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "echo 'No build step — bdralph is a bash entry point'",
    "lint": "shellcheck bin/bdralph src/loop/*.sh || true",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
