# =============================================================================
# bdralph — Environment Configuration
# =============================================================================
# Copy this file to .devcontainer/.env and fill in your values.
# .devcontainer/.env is gitignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTITY
# -----------------------------------------------------------------------------
GIT_USER_EMAIL=your-email-here
GIT_USER_NAME=your-github-username-here
TZ=America/Sao_Paulo  # e.g. America/New_York, Europe/London

# -----------------------------------------------------------------------------
# LLM PROVIDERS
# -----------------------------------------------------------------------------
# Required: OpenAI is the primary provider.
OPENAI_API_KEY=

# Optional: Gemini fallback for L2/L3 (M7+).
# GOOGLE_API_KEY=

# Optional: Anthropic direct API.
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# VERSION CONTROL
# -----------------------------------------------------------------------------
# Required for opening PRs via gh CLI.
GITHUB_TOKEN=your-github-token-here

# -----------------------------------------------------------------------------
# BDRALPH RUNTIME
# -----------------------------------------------------------------------------
# Required for E2E tests. Fails fast with clear message if absent.
# Values: no-llm | with-llm
# BDRALPH_E2E_MODE=no-llm

# Set to 1 to disable the Ink panel (CI, headless environments).
# BDRALPH_NO_UI=1

# Worker provider override. Default: openai.
# WORKER_PROVIDER=openai

# Worker model override. Default resolved per provider.
# WORKER_MODEL=

# Provider failover chains for L2/L3 (space-separated semantic names).
# BDRALPH_L2_PROVIDER_CHAIN=openai-cheap gemini-flash
# BDRALPH_L3_PROVIDER_CHAIN=openai-standard gemini-flash openai-mini
# BDRALPH_PROVIDER_FAILOVER=notify

# Gas Town — multi-loop parallelism. Opt-in explicit.
# BDRALPH_GAS_TOWN=enabled